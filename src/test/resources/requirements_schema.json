{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SAMPLE Project Traceability Schema",
  "type": "object",
  "properties": {
    "project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "lead": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    },
    "epics": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SAMPLE-E[0-9]+$"
          },
          "name": {
            "type": "string",
            "maxLength": 30
          },
          "description": {
            "type": "string"
          },
          "success_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^SAMPLE-F[0-9]+$"
                },
                "name": {
                  "type": "string",
                  "maxLength": 30
                },
                "success_criteria": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "stories": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "pattern": "^SAMPLE-S[0-9]+$"
                      },
                      "name": {
                        "type": "string",
                        "maxLength": 30
                      },
                      "description": {
                        "type": "string"
                      },
                      "success_criteria": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "tasks": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "pattern": "^SAMPLE-T[0-9]+$"
                            },
                            "name": {
                              "type": "string",
                              "maxLength": 50
                            },
                            "success_criterion": {
                              "type": "string"
                            },
                            "checks": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string",
                                    "pattern": "^SAMPLE-C[0-9]+$"
                                  },
                                  "scenario": {
                                    "type": "string"
                                  },
                                  "input": {
                                    "type": "string",
                                    "nullable": true
                                  },
                                  "input_type": {
                                    "type": "string",
                                    "default": "java.lang.String"
                                  },
                                  "operator": {
                                    "enum": [
                                      "EQUALS",
                                      "STARTS_WITH",
                                      "ENDS_WITH",
                                      "CONTAINS",
                                      "MATCHES_REGEX",
                                      "IS_NULL",
                                      "IS_NOT_NULL",
                                      "IS_EMPTY",
                                      "IS_BLANK"
                                    ]
                                  },
                                  "expected": {
                                    "type": "string"
                                  },
                                  "expected_type": {
                                    "type": "string",
                                    "default": "java.lang.String"
                                  },
                                  "ignore_case": {
                                    "type": "boolean",
                                    "default": false
                                  },
                                  "failed_message": {
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "id",
                                  "scenario",
                                  "operator"
                                ]
                              }
                            }
                          },
                          "required": [
                            "id",
                            "name",
                            "success_criterion",
                            "checks"
                          ]
                        }
                      }
                    },
                    "required": [
                      "id",
                      "name",
                      "success_criteria",
                      "tasks"
                    ]
                  }
                }
              },
              "required": [
                "id",
                "name",
                "success_criteria",
                "stories"
              ]
            }
          }
        },
        "required": [
          "id",
          "name",
          "success_criteria",
          "features"
        ]
      }
    }
  },
  "required": [
    "project",
    "epics"
  ]
}